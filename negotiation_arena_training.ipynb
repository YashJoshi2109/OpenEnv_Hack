      "cell_type": "code",
      "source": [
        "# Cell 1: Generate curves (works even if trainer_state is inside checkpoint folders)\n",
        "import os, glob, json\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "OUT_DIR = \"./grpo_output\"\n",
        "os.makedirs(\"./artifacts\", exist_ok=True)\n",
        "\n",
        "# ---------- A) Training loss curve ----------\n",
        "trainer_state_path = None\n",
        "candidates = [f\"{OUT_DIR}/trainer_state.json\"] + sorted(\n",
        "    glob.glob(f\"{OUT_DIR}/checkpoint-*/trainer_state.json\"),\n",
        "    key=lambda p: int(p.split(\"checkpoint-\")[-1].split(\"/\")[0])\n",
        ")\n",
        "\n",
        "for p in candidates[::-1]:  # prefer latest checkpoint state\n",
        "    if os.path.exists(p):\n",
        "        trainer_state_path = p\n",
        "        break\n",
        "\n",
        "loss_saved = False\n",
        "if trainer_state_path:\n",
        "    with open(trainer_state_path, \"r\") as f:\n",
        "        st = json.load(f)\n",
        "    logs = st.get(\"log_history\", [])\n",
        "    steps = [x[\"step\"] for x in logs if \"loss\" in x and \"step\" in x]\n",
        "    losses = [x[\"loss\"] for x in logs if \"loss\" in x and \"step\" in x]\n",
        "\n",
        "    if len(steps) > 0:\n",
        "        plt.figure(figsize=(8,5))\n",
        "        plt.plot(steps, losses, linewidth=2)\n",
        "        plt.title(\"GRPO Training Loss\")\n",
        "        plt.xlabel(\"Step\")\n",
        "        plt.ylabel(\"Loss\")\n",
        "        plt.grid(alpha=0.3)\n",
        "        plt.tight_layout()\n",
        "        plt.savefig(\"./artifacts/training_loss_curve.png\", dpi=200)\n",
        "        plt.show()\n",
        "        loss_saved = True\n",
        "        print(\"✅ Saved: ./artifacts/training_loss_curve.png\")\n",
        "else:\n",
        "    print(\"ℹ️ No trainer_state.json found (skipping loss curve).\")\n",
        "\n",
        "# ---------- B) Expert performance bar chart ----------\n",
        "experts = [\n",
        "    \"Sarah Chen — VP Engineering\",\n",
        "    \"Marcus Rivera — CFO\",\n",
        "    \"Dr. Aisha Patel — CTO\",\n",
        "    \"James O'Brien — HR Director\",\n",
        "    \"Elena Volkov — Founder/CEO\",\n",
        "]\n",
        "expert_rewards = [-3.000, -0.500, -3.312, -1.188, -2.688]\n",
        "expert_eps = [15, 11, 8, 8, 8]\n",
        "overall_deal_rate = 34.0\n",
        "overall_avg_reward = -2.16\n",
        "overall_avg_turns = 4.3\n",
        "\n",
        "y = np.arange(len(experts))\n",
        "plt.figure(figsize=(10,6))\n",
        "bars = plt.barh(y, expert_rewards)\n",
        "for i, b in enumerate(bars):\n",
        "    b.set_label(None)\n",
        "    if expert_rewards[i] >= -1.0:\n",
        "        b.set_color(\"#2ca02c\")\n",
        "    elif expert_rewards[i] >= -2.0:\n",
        "        b.set_color(\"#ffbf00\")\n",
        "    else:\n",
        "        b.set_color(\"#d62728\")\n",
        "\n",
        "plt.yticks(y, [f\"{e} ({n} eps)\" for e, n in zip(experts, expert_eps)])\n",
        "plt.axvline(overall_avg_reward, linestyle=\"--\", linewidth=1.5, label=f\"Overall Avg ({overall_avg_reward:.2f})\")\n",
        "plt.title(\"Per-Expert Reward Performance\")\n",
        "plt.xlabel(\"Average Reward\")\n",
        "plt.legend()\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"./artifacts/expert_performance.png\", dpi=200)\n",
        "plt.show()\n",
        "print(\"✅ Saved: ./artifacts/expert_performance.png\")\n",
        "\n",
        "# ---------- C) Deal rate donut ----------\n",
        "plt.figure(figsize=(5,5))\n",
        "sizes = [overall_deal_rate, 100-overall_deal_rate]\n",
        "labels = [\"Deal Reached\", \"No Deal\"]\n",
        "colors = [\"#2ca02c\", \"#d62728\"]\n",
        "wedges, texts, autotexts = plt.pie(\n",
        "    sizes, labels=labels, autopct=\"%1.1f%%\", startangle=90, colors=colors,\n",
        "    wedgeprops=dict(width=0.45)\n",
        ")\n",
        "plt.title(f\"Deal Rate ({overall_deal_rate:.1f}%)\")\n",
        "plt.tight_layout()\n",
        "plt.savefig(\"./artifacts/deal_rate_donut.png\", dpi=200)\n",
        "plt.show()\n",
        "print(\"✅ Saved: ./artifacts/deal_rate_donut.png\")"
      ],

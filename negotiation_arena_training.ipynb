      "cell_type": "code",
      "source": [
        "import torch\n",
        "import json\n",
        "import random\n",
        "import re\n",
        "from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig\n",
        "from peft import LoraConfig, get_peft_model, prepare_model_for_kbit_training\n",
        "from trl import GRPOTrainer, GRPOConfig\n",
        "from datasets import Dataset\n",
        "\n",
        "# ============================================================\n",
        "# CONFIG\n",
        "# ============================================================\n",
        "MODEL_NAME = \"Qwen/Qwen2.5-1.5B-Instruct\"\n",
        "OUT = \"./grpo_output\"\n",
        "HF_REPO = \"yashj2110/salary-negotiation-qwen-1.5b\"\n",
        "\n",
        "# Expert personas for curriculum\n",
        "EXPERT_PERSONAS = [\n",
        "    {\"name\": \"Sarah Chen\", \"style\": \"Analytical and data-driven\", \"tactic\": \"market_comparison\"},\n",
        "    {\"name\": \"Michael Torres\", \"style\": \"Aggressive negotiator\", \"tactic\": \"anchoring_high\"},\n",
        "    {\"name\": \"Jennifer Walsh\", \"style\": \"Relationship builder\", \"tactic\": \"win_win\"},\n",
        "    {\"name\": \"David Kim\", \"style\": \"Budget-conscious\", \"tactic\": \"budget_constraints\"},\n",
        "    {\"name\": \"Rachel Green\", \"style\": \"Fast closer\", \"tactic\": \"time_pressure\"},\n",
        "]\n",
        "\n",
        "# Curriculum Manager for self-improvement\n",
        "class CurriculumManager:\n",
        "    def __init__(self):\n",
        "        self.perf = {p[\"name\"]: [] for p in EXPERT_PERSONAS}\n",
        "\n",
        "    def record(self, expert_name, reward):\n",
        "        if expert_name in self.perf:\n",
        "            self.perf[expert_name].append(reward)\n",
        "\n",
        "    def get_weights():\n",
        "        weights = {}\n",
        "        for name, rewards in self.perf.items():\n",
        "            if len(rewards) >= 5:\n",
        "                avg = sum(rewards[-20:]) / len(rewards[-20:])\n",
        "                weights[name] = max(0.1, 1.0 - avg)\n",
        "            else:\n",
        "                weights[name] = 1.0 / len(EXPERT_PERSONAS)\n",
        "        total = sum(weights.values())\n",
        "        return {k: v/total for k, v in weights.items()}\n",
        "\n",
        "curriculum = CurriculumManager()\n",
        "\n",
        "# ============================================================\n",
        "# REWARD FUNCTION (FIXED)\n",
        "# ============================================================\n",
        "def reward_fn(completions, **kw):\n",
        "    \"\"\"Reward based on negotiation outcomes.\"\"\"\n",
        "    rewards = []\n",
        "    for c in completions:\n",
        "        txt = c[0][\"content\"] if isinstance(c, list) else str(c)\n",
        "        try:\n",
        "            m = re.search(r'\\{[^{}]*\\}', txt)\n",
        "            if not m:\n",
        "                rewards.append(0.0)\n",
        "                continue\n",
        "            p = json.loads(m.group())\n",
        "            r = 0.0\n",
        "\n",
        "            # Check base_salary\n",
        "            base = p.get(\"base_salary\", 0)\n",
        "            if isinstance(base, (int, float)):\n",
        "                if base >= 100000:\n",
        "                    r += 0.4\n",
        "                elif base >= 95000:\n",
        "                    r += 0.3\n",
        "                elif base >= 90000:\n",
        "                    r += 0.2\n",
        "\n",
        "            # Check equity (FIXED: use variable, not p[\"equity\"])\n",
        "            equity = p.get(\"equity\", 0)\n",
        "            if isinstance(equity, (int, float)) and equity >= 0.2:\n",
        "                r += 0.2\n",
        "\n",
        "            # Check message (FIXED: use variable, not p[\"message\"])\n",
        "            msg = p.get(\"message\", \"\")\n",
        "            if isinstance(msg, str) and len(msg) > 20:\n",
        "                r += 0.2\n",
        "\n",
        "            # Bonus for valid action type\n",
        "            action = p.get(\"action_type\", \"\")\n",
        "            if action in [\"propose\", \"counter\", \"accept\"]:\n",
        "                r += 0.1\n",
        "\n",
        "            rewards.append(min(1.0, r))\n",
        "        except Exception as e:\n",
        "            rewards.append(0.0)\n",
        "    return rewards\n",
        "\n",
        "# ============================================================\n",
        "# PROMPT GENERATION\n",
        "# ============================================================\n",
        "def gen_prompts(n=200):\n",
        "    \"\"\"Generate training prompts with curriculum-weighted sampling.\"\"\"\n",
        "    sys_prompt = (\n",
        "        \"You are a skilled salary negotiator (candidate). Respond ONLY with JSON: \"\n",
        "        '{\"action_type\": \"propose|counter|accept|reject|walk_away\", '\n",
        "        '\"base_salary\": 95000, \"equity\": 0.15, \"start_date\": \"2024-03-01\", '\n",
        "        '\"message\": \"your negotiation message\"}. '\n",
        "        \"Aim for the best deal possible.\"\n",
        "    )\n",
        "\n",
        "    prompts = []\n",
        "    weights = curriculum.get_weights()\n",
        "    expert_names = [p[\"name\"] for p in EXPERT_PERSONAS]\n",
        "    expert_weights = [weights.get(name, 0.2) for name in expert_names]\n",
        "\n",
        "    scenarios = [\n",
        "        \"Initial offer: $85,000 base, 0.1% equity, start in 2 weeks.\",\n",
        "        \"Counter-offer: $90,000 base, 0.15% equity, flexible start date.\",\n",
        "        \"Final offer: $88,000 base, 0.2% equity, signing bonus $5,000.\",\n",
        "        \"Verbal offer: $92,000 base, standard benefits, start next month.\",\n",
        "        \"Revised offer: $87,000 base, 0.25% equity, remote work option.\",\n",
        "    ]\n",
        "\n",
        "    for _ in range(n):\n",
        "        expert_idx = random.choices(range(len(EXPERT_PERSONAS)), weights=expert_weights, k=1)[0]\n",
        "        expert = EXPERT_PERSONAS[expert_idx]\n",
        "        scenario = random.choice(scenarios)\n",
        "\n",
        "        user_msg = f\"[HR: {expert['name']} - {expert['style']}]\\n{scenario}\\nYour response:\"\n",
        "\n",
        "        prompts.append({\n",
        "            \"prompt\": [\n",
        "                {\"role\": \"system\", \"content\": sys_prompt},\n",
        "                {\"role\": \"user\", \"content\": user_msg}\n",
        "            ],\n",
        "            \"expert\": expert[\"name\"]\n",
        "        })\n",
        "\n",
        "    return prompts\n",
        "\n",
        "# ============================================================\n",
        "# MAIN TRAINING\n",
        "# ============================================================\n",
        "print(\"=\" * 60)\n",
        "print(\"🏆 SalaryNegotiationArena — GRPO Training\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# [1/4] Load model with 4-bit quantization\n",
        "print(\"\\n[1/4] Loading Qwen 1.5B (4-bit)...\")\n",
        "bnb_config = BitsAndBytesConfig(\n",
        "    load_in_4bit=True,\n",
        "    bnb_4bit_quant_type=\"nf4\",\n",
        "    bnb_4bit_compute_dtype=torch.float16,  # Use fp16 for A100\n",
        "    bnb_4bit_use_double_quant=True,\n",
        ")\n",
        "\n",
        "model = AutoModelForCausalLM.from_pretrained(\n",
        "    MODEL_NAME,\n",
        "    quantization_config=bnb_config,\n",
        "    device_map=\"auto\",\n",
        "    torch_dtype=torch.float16,\n",
        "    trust_remote_code=True,\n",
        ")\n",
        "\n",
        "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME, trust_remote_code=True)\n",
        "if tokenizer.pad_token is None:\n",
        "    tokenizer.pad_token = tokenizer.eos_token\n",
        "\n",
        "print(\"✅ Model loaded!\")\n",
        "\n",
        "# [2/4] Add LoRA\n",
        "print(\"\\n[2/4] Adding LoRA...\")\n",
        "model = prepare_model_for_kbit_training(model)\n",
        "\n",
        "lora_config = LoraConfig(\n",
        "    r=16,\n",
        "    lora_alpha=16,\n",
        "    target_modules=[\"q_proj\", \"k_proj\", \"v_proj\", \"o_proj\", \"gate_proj\", \"up_proj\", \"down_proj\"],\n",
        "    lora_dropout=0.05,\n",
        "    bias=\"none\",\n",
        "    task_type=\"CAUSAL_LM\",\n",
        ")\n",
        "\n",
        "model = get_peft_model(model, lora_config)\n",
        "model.warnings_issued = {\"estimate_tokens\": True}  # Fix TRL bug\n",
        "model.print_trainable_parameters()\n",
        "\n",
        "# [3/4] Generate dataset\n",
        "print(\"\\n[3/4] Generating dataset...\")\n",
        "ds = gen_prompts(200)\n",
        "train_ds = Dataset.from_dict({\"prompt\": [d[\"prompt\"] for d in ds]})\n",
        "print(f\"✅ {len(train_ds)} training samples ready\")\n",
        "\n",
        "# [4/4] Train with GRPO\n",
        "print(\"\\n[4/4] Starting GRPO training...\")\n",
        "cfg = GRPOConfig(\n",
        "    output_dir=OUT,\n",
        "    num_train_epochs=3,\n",
        "    per_device_train_batch_size=2,\n",
        "    gradient_accumulation_steps=8,\n",
        "    learning_rate=5e-6,\n",
        "    lr_scheduler_type=\"cosine\",\n",
        "    num_generations=4,\n",
        "    max_completion_length=256,\n",
        "    logging_steps=5,\n",
        "    save_steps=50,\n",
        "    fp16=True,\n",
        "    bf16=False,\n",
        "    report_to=\"none\",\n",
        "    remove_unused_columns=False,\n",
        ")\n",
        "\n",
        "trainer = GRPOTrainer(\n",
        "    model=model,\n",
        "    processing_class=tokenizer,\n",
        "    args=cfg,  # Changed 'config' to 'args'\n",
        "    train_dataset=train_ds,\n",
        "    reward_funcs=reward_fn\n",
        ")\n",
        "\n",
        "trainer.train()\n",
        "\n",
        "# Save\n",
        "trainer.save_model(OUT)\n",
        "tokenizer.save_pretrained(OUT)\n",
        "\n",
        "print(\"\\n\" + \"=\" * 60)\n",
        "print(\"✅ Training complete!\")\n",
        "print(f\"📁 Model saved to: {OUT}\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# Optional: Push to HuggingFace\n",
        "# from huggingface_hub import login\n",
        "# login(token=\"YOUR_HF_TOKEN\")\n",
        "# model.push_to_hub(HF_REPO)\n",
        "# tokenizer.push_to_hub(HF_REPO)\n"
      ],

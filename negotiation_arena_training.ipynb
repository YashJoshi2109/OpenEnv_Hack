      "cell_type": "code",
      "source": [
        "# Cell 2: Upload curve images to your Hugging Face model repo\n",
        "from huggingface_hub import login, HfApi\n",
        "\n",
        "repo_id = \"yashj2110/salary-negotiation-qwen-1.5b\"  # your model repo\n",
        "login()  # paste token when prompted\n",
        "\n",
        "api = HfApi()\n",
        "files = [\n",
        "    \"./artifacts/expert_performance.png\",\n",
        "    \"./artifacts/deal_rate_donut.png\",\n",
        "]\n",
        "# include loss curve if it exists\n",
        "import os\n",
        "if os.path.exists(\"./artifacts/training_loss_curve.png\"):\n",
        "    files.append(\"./artifacts/training_loss_curve.png\")\n",
        "\n",
        "for fp in files:\n",
        "    api.upload_file(\n",
        "        path_or_fileobj=fp,\n",
        "        path_in_repo=f\"assets/{os.path.basename(fp)}\",\n",
        "        repo_id=repo_id,\n",
        "        repo_type=\"model\",\n",
        "    )\n",
        "    print(\"✅ Uploaded:\", fp)\n",
        "\n",
        "print(\"\\nAdd these lines to your model card README.md:\\n\")\n",
        "print(\"![Expert Performance](./assets/expert_performance.png)\")\n",
        "print(\"![Deal Rate](./assets/deal_rate_donut.png)\")\n",
        "if os.path.exists(\"./artifacts/training_loss_curve.png\"):\n",
        "    print(\"![Training Loss](./assets/training_loss_curve.png)\")"
      ],

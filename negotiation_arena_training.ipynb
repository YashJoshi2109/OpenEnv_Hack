        "# Verify your uploaded adapter from Hugging Face\n",
        "import torch\n",
        "from transformers import AutoTokenizer, AutoModelForCausalLM\n",
        "from peft import PeftModel\n",
        "\n",
        "repo_id = \"yashj2110/salary-negotiation-qwen-1.5b\"\n",
        "base_model_id = \"Qwen/Qwen2.5-1.5B-Instruct\"\n",
        "\n",
        "print(\"Loading tokenizer...\")\n",
        "tokenizer = AutoTokenizer.from_pretrained(repo_id, trust_remote_code=True)\n",
        "if tokenizer.pad_token is None:\n",
        "    tokenizer.pad_token = tokenizer.eos_token\n",
        "\n",
        "print(\"Loading base model...\")\n",
        "base_model = AutoModelForCausalLM.from_pretrained(\n",
        "    base_model_id,\n",
        "    torch_dtype=torch.float16,\n",
        "    device_map=\"auto\",\n",
        "    trust_remote_code=True\n",
        ")\n",
        "\n",
        "print(\"Loading adapter...\")\n",
        "model = PeftModel.from_pretrained(base_model, repo_id)\n",
        "model.eval()\n",
        "\n",
        "prompt = \"\"\"You are a salary negotiation agent.\n",
        "Respond ONLY in JSON with keys:\n",
        "action_type, base_salary, equity, start_date, message.\n",
        "\n",
        "HR offer: $90,000 base, 0.10% equity, start in 30 days.\n",
        "\"\"\"\n",
        "\n",
        "inputs = tokenizer(prompt, return_tensors=\"pt\").to(model.device)\n",
        "with torch.no_grad():\n",
        "    out = model.generate(\n",
        "        **inputs,\n",
        "        max_new_tokens=120,\n",
        "        temperature=0.7,\n",
        "        do_sample=True,\n",
        "        pad_token_id=tokenizer.eos_token_id\n",
        "    )\n",
        "\n",
        "text = tokenizer.decode(out[0], skip_special_tokens=True)\n",
        "print(\"\\n=== Generated Output ===\\n\")\n",
        "print(text)\n",
        "print(\"\\n✅ If this runs, your Hub upload is good.\")"
      ],

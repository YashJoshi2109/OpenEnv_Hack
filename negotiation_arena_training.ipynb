      "cell_type": "code",
      "source": [
        "from pathlib import Path\n",
        "from huggingface_hub import login, create_repo, upload_folder\n",
        "\n",
        "# 1) Login\n",
        "login(token="YOUR_HF_TOKEN")  # set via HF_TOKEN env var  # replace\n",
        "\n",
        "# 2) Find saved output folder\n",
        "candidates = [\n",
        "    Path(\"./grpo_output\"),\n",
        "    Path(\"/content/grpo_output\"),\n",
        "    Path(\"/content/OpenEnv Hack/grpo_output\"),\n",
        "]\n",
        "out_dir = next((p for p in candidates if p.exists()), None)\n",
        "print(\"Found:\", out_dir)\n",
        "\n",
        "if out_dir is None:\n",
        "    raise FileNotFoundError(\"grpo_output folder not found\")\n",
        "\n",
        "# 3) Push folder to Hub (no trainer needed)\n",
        "repo_id = \"yashj2110/salary-negotiation-qwen-1.5b\"\n",
        "create_repo(repo_id, exist_ok=True)\n",
        "\n",
        "upload_folder(\n",
        "    repo_id=repo_id,\n",
        "    folder_path=str(out_dir),\n",
        "    path_in_repo=\"\",\n",
        "    commit_message=\"Upload trained GRPO adapter output\"\n",
        ")\n",
        "\n",
        "print(f\"✅ Uploaded to https://huggingface.co/{repo_id}\")"
      ],

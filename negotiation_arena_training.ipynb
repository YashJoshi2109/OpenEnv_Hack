        "import json\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "# 1. Load and visualize training loss\n",
        "try:\n",
        "    with open('./grpo_output/trainer_state.json', 'r') as f:\n",
        "        state = json.load(f)\n",
        "\n",
        "    steps = [x['step'] for x in state['log_history'] if 'loss' in x]\n",
        "    losses = [x['loss'] for x in state['log_history'] if 'loss' in x]\n",
        "\n",
        "    plt.figure(figsize=(12, 5))\n",
        "    plt.subplot(1, 2, 1)\n",
        "    plt.plot(steps, losses, 'b-', linewidth=2)\n",
        "    plt.title('GRPO Training Loss', fontsize=14, fontweight='bold')\n",
        "    plt.xlabel('Step')\n",
        "    plt.ylabel('Loss')\n",
        "    plt.grid(True, alpha=0.3)\n",
        "\n",
        "    # 2. Parse evaluation results (from your screenshot)\n",
        "    experts = ['Sarah Chen', 'Marcus Rivera', 'Dr. Aisha Patel', 'James O\\'Brien', 'Elena Volkov']\n",
        "    rewards = [-3.0, -0.5, -3.312, -1.188, -2.688]\n",
        "    episodes = [15, 11, 8, 8, 8]\n",
        "\n",
        "    plt.subplot(1, 2, 2)\n",
        "    colors = ['#2ecc71' if r > -1.5 else '#e74c3c' if r < -2.5 else '#f39c12' for r in rewards]\n",
        "    bars = plt.barh(experts, rewards, color=colors)\n",
        "    plt.axvline(x=-2.16, color='gray', linestyle='--', label='Overall Avg')\n",
        "    plt.title('Per-Expert Performance', fontsize=14, fontweight='bold')\n",
        "    plt.xlabel('Avg Reward')\n",
        "    plt.legend()\n",
        "    plt.tight_layout()\n",
        "    plt.savefig('training_results.png', dpi=300, bbox_inches='tight')\n",
